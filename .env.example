# ============================================================
#  MLOPS- Environment Variables
#  Military Logistics Optimization & Prediction System
# ============================================================
#  COPY this file to .env and fill in your real values.
#  NEVER commit .env to Git- it is in .gitignore.
# ============================================================

# MySQL Database (mlops_db)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mlops_db
DB_USER=user
DB_PASSWORD=user

# Django
SECRET_KEY=your-django-secret-key-here-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=True

# ML runtime (optional)
# Leave blank to auto-use .venv/Scripts/python.exe when present.
ML_PYTHON_EXECUTABLE=

# Blockchain (Ganache)
GANACHE_URL=http://127.0.0.1:7545
GANACHE_RPC_URL=http://127.0.0.1:7545
GANACHE_CHAIN_ID=1337
